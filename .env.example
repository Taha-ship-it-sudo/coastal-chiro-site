# OpenAI — powers the 24/7 FAQ chat and review reply drafts
OPENAI_API_KEY=sk-...

# Optional: restrict /api/reviews/respond (review reply generator)
REVIEW_ASSISTANT_TOKEN=your-secret-token

# Resend — newsletter signups (create audience at resend.com/audiences)
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...
# From address must use a domain you've verified in Resend
RESEND_FROM_EMAIL=Coastal Chiropractic SLO <newsletter@yourdomain.com>
# Optional: internal alert when someone subscribes
NEWSLETTER_NOTIFY_EMAIL=office@yourdomain.com

# Fullscript — shown in welcome popup + returned from /api/newsletter after signup
FULLSCRIPT_PROMO_CODE=YOURCODE10
# Optional extra line in the welcome email (HTML escaped server-side)
FULLSCRIPT_PROMO_NOTE=Applies to qualifying Fullscript orders per clinic policy.
